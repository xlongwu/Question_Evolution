{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Question Evolution Metadata",
  "type": "object",
  "additionalProperties": true,
  "required": ["question_evolved"],
  "properties": {
    "question_evolved": {
      "type": "boolean"
    },
    "trigger_score_rate": {
      "type": ["number", "null"],
      "minimum": 0,
      "maximum": 1
    },
    "question_evolution_model": {
      "type": "string"
    },
    "operator_used": {
      "type": "string"
    },
    "ability_axis": {
      "type": "string"
    },
    "target_subclaim": {
      "type": "string"
    },
    "boundary_hypothesis": {
      "type": "string"
    },
    "expected_qwen_failure": {
      "type": "string"
    },
    "expected_evaluation_focus": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "evolution_strategy": {
      "type": "string"
    },
    "notes_for_reference": {
      "type": "string"
    },
    "question_evolution_raw_response": {
      "type": "string"
    },
    "complexity_budget": {
      "type": "object",
      "additionalProperties": true
    }
  }
}
