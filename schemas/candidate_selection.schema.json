{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Candidate Selection",
  "type": "object",
  "additionalProperties": true,
  "required": ["selected_candidate_id", "selected_operator", "selection_reason"],
  "properties": {
    "selected_candidate_id": {
      "type": "string"
    },
    "selected_operator": {
      "type": "string"
    },
    "selection_reason": {
      "type": "string"
    },
    "rejected_candidates": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": ["candidate_id", "reject_reason"],
        "properties": {
          "candidate_id": {
            "type": "string"
          },
          "reject_reason": {
            "type": "string"
          }
        }
      }
    }
  }
}
