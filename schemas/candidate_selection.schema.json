{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Candidate Selection",
  "type": "object",
  "additionalProperties": true,
  "required": ["selected_candidate_id", "selected_operator", "selection_reason"],
  "properties": {
    "selected_candidate_id": {
      "type": "string"
    },
    "selected_operator": {
      "type": "string"
    },
    "selection_reason": {
      "type": "string"
    },
    "selected_into_mainline": {
      "type": "boolean"
    },
    "selected_as_boundary_leaf": {
      "type": "boolean"
    },
    "discard_as_duplicate": {
      "type": "boolean"
    },
    "dedup_signature": {
      "type": "string"
    },
    "boundary_axis_detected": {
      "type": ["string", "null"]
    },
    "target_boundary_axis": {
      "type": ["string", "null"]
    },
    "boundary_candidate_status": {
      "type": ["string", "null"]
    },
    "rejected_candidates": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": ["candidate_id", "reject_reason"],
        "properties": {
          "candidate_id": {
            "type": "string"
          },
          "reject_reason": {
            "type": "string"
          },
          "discard_as_duplicate": {
            "type": "boolean"
          },
          "selected_as_boundary_leaf": {
            "type": "boolean"
          },
          "dedup_signature": {
            "type": "string"
          }
        }
      }
    }
  }
}
